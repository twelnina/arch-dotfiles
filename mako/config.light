font=Noto Sans 10
background-color=#f5f5f777
text-color=#1d1d1f
border-color=#0000000f
progress-color=over #007aff18

width=380
height=112
padding=14,16
margin=10
outer-margin=18
border-size=1
border-radius=16

anchor=top-right
layer=overlay
default-timeout=5000
max-visible=4

icons=1
max-icon-size=44
icon-border-radius=10
markup=1
actions=1
format=<b>%s</b>\n%b
